# Smartschool credentials
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

SMARTSCHOOL_USERNAME=your_username
SMARTSCHOOL_PASSWORD=your_password
SMARTSCHOOL_MAIN_URL=your-school.smartschool.be
SMARTSCHOOL_MFA=YYYY-MM-DD # date of birth (e.g. 2008-07-15) - required if your account uses account verification, leave blank otherwise

# Remote HTTP transport
MCP_TRANSPORT=streamable-http
MCP_HOST=127.0.0.1
MCP_PORT=8000

# Optional: protect the /mcp endpoint with a Bearer token
# Set the same value in claude.ai when adding the custom connector
# MCP_API_KEY=change-me-to-a-long-random-secret
